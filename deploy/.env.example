# Copy to deploy/.env on the VPS (never commit the real .env).
PORT=8080
DB_PATH=/data/shortlink.db
# Short links are minted on this host; short-link.fun's Worker must serve /{code}
# (proxy/redirect to api.short-link.fun). Use api.short-link.fun here if the BE
# should own the redirects instead.
BASE_URL=https://short-link.fun
CORS_ALLOWED_ORIGINS=https://short-link.fun
# Fixed forever once data exists — changing it makes existing codes undecodable.
FEISTEL_KEY=replace-with-openssl-rand-hex-32
