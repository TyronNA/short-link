# ShortLink configuration — copy to .env for local use (.env is gitignored).
# The app reads these from the process environment (12-factor); it does NOT
# auto-load .env. To use this file locally:
#     export $(grep -v '^#' .env | xargs)
# or just pass vars to `make run` / `make start` (e.g. make run PORT=9000).

# TCP port to listen on.
PORT=8080

# SQLite database file path (created if absent). Mount on a volume in Docker
# so data persists across restarts.
DB_PATH=shortlink.db

# Prefix used to build returned short URLs.
BASE_URL=http://localhost:8080

# Secret that parameterizes the short-code permutation.
# MUST be set to a strong, private value in production — if leaked, short codes
# become enumerable. Generate one with:  openssl rand -hex 16
FEISTEL_KEY=change-me-in-production
